{
  "shadows": {
    "none": {
      "$type": "shadow",
      "$value": {
        "color":   "rgba(0, 0, 0, 0)",
        "offsetX": "0px",
        "offsetY": "0px",
        "blur":    "0px",
        "spread":  "0px"
      }
    },
    "xs": {
      "$type": "shadow",
      "$value": {
        "color":   "rgba(15, 23, 42, 0.04)",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur":    "2px",
        "spread":  "0px"
      }
    },
    "sm": {
      "$type": "shadow",
      "$value": [
        {
          "color":   "rgba(15, 23, 42, 0.06)",
          "offsetX": "0px",
          "offsetY": "1px",
          "blur":    "3px",
          "spread":  "0px"
        },
        {
          "color":   "rgba(15, 23, 42, 0.05)",
          "offsetX": "0px",
          "offsetY": "1px",
          "blur":    "2px",
          "spread":  "-1px"
        }
      ]
    },
    "md": {
      "$type": "shadow",
      "$value": [
        {
          "color":   "rgba(15, 23, 42, 0.08)",
          "offsetX": "0px",
          "offsetY": "4px",
          "blur":    "6px",
          "spread":  "-1px"
        },
        {
          "color":   "rgba(15, 23, 42, 0.06)",
          "offsetX": "0px",
          "offsetY": "2px",
          "blur":    "4px",
          "spread":  "-2px"
        }
      ]
    },
    "lg": {
      "$type": "shadow",
      "$value": [
        {
          "color":   "rgba(15, 23, 42, 0.08)",
          "offsetX": "0px",
          "offsetY": "10px",
          "blur":    "15px",
          "spread":  "-3px"
        },
        {
          "color":   "rgba(15, 23, 42, 0.06)",
          "offsetX": "0px",
          "offsetY": "4px",
          "blur":    "6px",
          "spread":  "-4px"
        }
      ]
    }
  }
}
